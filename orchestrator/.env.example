# Orchestrator
PORT=3001
PUBLIC_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# Postgres (local dev)
DATABASE_URL=postgres://ndstab@localhost:5432/fetch_dev

# Locus — mock | real
LOCUS_MODE=mock
LOCUS_API_KEY=
LOCUS_API_BASE=https://api.paywithlocus.com
LOCUS_BUILD_API_BASE=https://api.buildwithlocus.com/v1
