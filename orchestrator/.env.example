# Orchestrator
PORT=3001
PUBLIC_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# Postgres (local dev)
DATABASE_URL=postgres://ndstab@localhost:5432/fetch_dev

# Locus — mock | real
LOCUS_MODE=mock

# Populated by `npm run bootstrap-locus` (self-registers a beta agent).
LOCUS_API_KEY=
LOCUS_API_BASE=https://beta-api.paywithlocus.com/api
LOCUS_BUILD_API_BASE=https://api.buildwithlocus.com/v1
LOCUS_WALLET_ADDRESS=
# Fallback global webhook secret. Usually the per-session whsec_* returned by
# sessions.create is used and stored on the quest row; this is a backstop.
LOCUS_WEBHOOK_SECRET=
# Override if Locus gives you a non-standard checkout session endpoint.
# LOCUS_CHECKOUT_CREATE_PATH=/checkout/sessions

# Quest container image. Must be publicly pullable by the Build-with-Locus
# registry, or built from a GitHub source you've connected via the dashboard.
QUEST_IMAGE_URI=ghcr.io/your-org/fetch-quest-runtime:latest

# Platform
SERVICE_FEE_BPS=1000   # 10%
